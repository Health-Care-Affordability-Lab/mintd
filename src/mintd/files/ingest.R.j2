#' Data ingestion for {{ project_name }}
#'
#' Reads data/raw/ (immutable source data), parses and normalizes it, and
#' writes data/intermediate/. This is the first stage of the DVC pipeline
#' (ingest -> validate).
#'
#' NOTE: This script runs from the code/ directory. Data paths use ../data/
#'
#' data/raw/ is treated as IMMUTABLE: this script reads it but never writes to
#' it. To update raw data, either re-run the optional `fetch` stage (see
#' fetch.R / dvc.yaml) or run `dvc add data/raw/` after manually updating files.
#'
#' For large datasets with expensive parsing, consider separating `parse_*`
#' functions (raw formats -> data frames) from `clean_*` functions
#' (business-logic standardization). If the clean_* helpers grow, split them
#' into their own file — and into their own dvc.yaml stage between ingest and
#' validate.

# Import mint utilities (located in same code/ directory)
source("_mintd_utils.R")

# Load tidyverse for data manipulation
library(dplyr, warn.conflicts = FALSE)
library(readr)
library(stringr)

#' Normalize a raw data frame into analysis-ready intermediate form.
#'
#' Customize with your project's parsing/cleaning logic. The default applies
#' safe, generic standardization (drop empty rows, strip whitespace, normalize
#' column names).
parse_and_clean <- function(df, logger) {
  initial_rows <- nrow(df)
  df <- df %>% filter(rowSums(is.na(.)) < ncol(.))
  if (initial_rows - nrow(df) > 0) {
    logger$log("  Removed ", initial_rows - nrow(df), " empty rows")
  }

  char_cols <- names(df)[sapply(df, is.character)]
  if (length(char_cols) > 0) {
    df <- df %>% mutate(across(all_of(char_cols), str_trim))
    logger$log("  Stripped whitespace from ", length(char_cols), " character columns")
  }

  names(df) <- names(df) %>%
    tolower() %>%
    str_replace_all(" ", "_") %>%
    str_replace_all("-", "_")
  logger$log("  Final row count: ", nrow(df))
  return(df)
}

main <- function() {
  logger <- ParameterAwareLogger("ingest")
  logger$log("Starting data ingestion for {{ project_name }}...")

  # Ensure pipeline directories exist (raw is read-only here; do NOT write it).
  paths <- get_data_paths()
  lapply(paths, function(d) {
    if (!dir.exists(d)) dir.create(d, recursive = TRUE)
  })

  logger$log("Reading raw data from: ", RAW_DIR)
  logger$log("Writing intermediate data to: ", INTERMEDIATE_DIR)

  raw_files <- list.files(RAW_DIR, pattern = "\\.csv$", full.names = TRUE)
  if (length(raw_files) == 0) {
    logger$log(
      "No CSV files found in RAW_DIR. Place source data in data/raw/ ",
      "(or run `dvc repro fetch` if using programmatic acquisition)."
    )
  } else {
    logger$log("Found ", length(raw_files), " raw file(s) to ingest")
    for (raw_file in raw_files) {
      logger$log("Processing: ", basename(raw_file))
      # ----------------------------------------------------------------------
      # CUSTOMIZE: read each raw format, normalize, write to intermediate.
      #   CSV:     df <- read_csv(raw_file, show_col_types = FALSE)
      #   Excel:   df <- readxl::read_excel(raw_file)
      # ----------------------------------------------------------------------
      df <- read_csv(raw_file, show_col_types = FALSE)
      logger$log("  Loaded ", nrow(df), " rows, ", ncol(df), " columns")

      df <- parse_and_clean(df, logger)

      output_file <- file.path(INTERMEDIATE_DIR, basename(raw_file))
      write_csv(df, output_file)
      logger$log("  Wrote: ", basename(output_file))
    }
  }

  logger$log("Data ingestion completed successfully.")
  logger$close()
}

if (!interactive()) {
  main()
}
