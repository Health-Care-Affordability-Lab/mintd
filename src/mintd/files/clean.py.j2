"""Data quality inspection helper for {{ project_name }}.

STANDALONE TOOL — this is NOT a DVC pipeline stage. The pipeline's cleaning
logic lives in ingest.py (which reads data/raw/ and writes data/intermediate/).
This script reads the already-ingested data/intermediate/ files and reports
what `clean_dataset` would change, WITHOUT writing any output. Use it to audit
data quality interactively after running the pipeline.

Run it after `dvc repro ingest` has populated data/intermediate/.

NOTE: This script runs from the code/ directory. Data paths use ../data/

The cleaning functions below are importable utilities — ingest.py may call
`clean_dataset` directly.
"""

import pandas as pd

# Import mint utilities (located in same code/ directory)
from _mintd_utils import (
    ParameterAwareLogger,
    INTERMEDIATE_DIR,
)


def clean_dataset(df, logger):
    """Apply standard cleaning operations to a DataFrame.

    Operations:
    - Remove completely empty rows
    - Strip whitespace from string columns
    - Standardize column names (lowercase, underscores)

    Args:
        df: pandas DataFrame to clean
        logger: Logger instance for logging

    Returns:
        Cleaned DataFrame
    """
    initial_rows = len(df)

    # Remove completely empty rows
    df = df.dropna(how='all')
    empty_removed = initial_rows - len(df)
    if empty_removed > 0:
        logger.log(f"  Removed {empty_removed} empty rows")

    # Strip whitespace from string columns
    string_cols = df.select_dtypes(include=['object']).columns
    for col in string_cols:
        df[col] = df[col].astype(str).str.strip()
        # Convert 'nan' strings back to NaN
        df[col] = df[col].replace('nan', pd.NA)
    if len(string_cols) > 0:
        logger.log(f"  Stripped whitespace from {len(string_cols)} string columns")

    # Standardize column names
    original_cols = list(df.columns)
    df.columns = df.columns.str.lower().str.replace(' ', '_').str.replace('-', '_')
    renamed = sum(1 for a, b in zip(original_cols, df.columns) if a != b)
    if renamed > 0:
        logger.log(f"  Standardized {renamed} column names")

    logger.log(f"  Final row count: {len(df)}")
    return df


def main():
    """Inspect intermediate data quality. Reads data/intermediate/, reports what
    cleaning would do, and writes NOTHING — the pipeline owns those files."""
    logger = ParameterAwareLogger("clean")
    logger.log("Inspecting intermediate data quality for {{ project_name }}...")
    logger.log(
        "This is a read-only audit. It does NOT modify any files. "
        "Run `dvc repro ingest` first if data/intermediate/ is empty."
    )

    intermediate_files = list(INTERMEDIATE_DIR.glob("*.csv"))
    if not intermediate_files:
        logger.log(
            "No CSV files found in INTERMEDIATE_DIR. Run `dvc repro ingest` first."
        )
    else:
        logger.log(f"Found {len(intermediate_files)} intermediate file(s) to inspect")
        for data_file in intermediate_files:
            logger.log(f"Inspecting: {data_file.name}")
            df = pd.read_csv(data_file)
            logger.log(f"  Loaded {len(df)} rows, {len(df.columns)} columns")
            # Report what cleaning would change; discard the result (no write).
            clean_dataset(df.copy(), logger)

    logger.log("Data quality inspection completed.")
    logger.close()


if __name__ == "__main__":
    main()
