* Data ingestion for {{ project_name }}
*
* Reads data/raw/ (immutable source data), parses and normalizes it, and
* writes data/intermediate/. This is the first stage of the DVC pipeline
* (ingest -> validate).
*
* NOTE: This script runs from the code/ directory. Data paths use ../data/
*
* data/raw/ is treated as IMMUTABLE: this do-file reads it but never writes to
* it. To update raw data, either re-run the optional `fetch` stage (see
* fetch.do / dvc.yaml) or run `dvc add data/raw/` after manually updating files.
*
* For large projects with expensive parsing, consider separating parse
* programs (raw formats -> Stata datasets) from clean programs
* (business-logic standardization).

* Import mint utilities (located in same code/ directory)
do _mintd_utils.do

* Normalize a loaded dataset into analysis-ready intermediate form.
* Customize with your project's parsing/cleaning logic. The default applies
* safe, generic standardization (drop empty rows, strip whitespace, lowercase
* variable names).
capture program drop parse_and_clean
program define parse_and_clean
    local initial_rows = _N

    egen _row_missing = rowmiss(_all)
    local total_vars = c(k) - 1  // exclude _row_missing
    drop if _row_missing == `total_vars'
    local empty_removed = `initial_rows' - _N
    drop _row_missing
    if `empty_removed' > 0 {
        log_message "  Removed `empty_removed' empty rows"
    }

    local string_count = 0
    foreach var of varlist _all {
        capture confirm string variable `var'
        if !_rc {
            replace `var' = strtrim(`var')
            local ++string_count
        }
    }
    if `string_count' > 0 {
        log_message "  Stripped whitespace from `string_count' string variables"
    }

    rename *, lower
    log_message "  Final row count: `c(N)'"
end

// Main ingestion program
capture program drop main
program define main
    ParameterAwareLogger ingest
    log_message "Starting data ingestion for {{ project_name }}..."

    * Ensure pipeline directories exist (raw is read-only here; do NOT write it).
    capture mkdir "$DATA_DIR"
    capture mkdir "$INTERMEDIATE_DIR"
    capture mkdir "$FINAL_DIR"

    log_message "Reading raw data from: $RAW_DIR"
    log_message "Writing intermediate data to: $INTERMEDIATE_DIR"

    local raw_files : dir "$RAW_DIR" files "*.csv"
    local file_count : word count `raw_files'

    if `file_count' == 0 {
        log_message "No CSV files found in RAW_DIR. Place source data in data/raw/"
        log_message "(or run dvc repro fetch if using programmatic acquisition)."
    }
    else {
        log_message "Found `file_count' raw file(s) to ingest"
        foreach file of local raw_files {
            log_message "Processing: `file'"
            * ------------------------------------------------------------------
            * CUSTOMIZE: read each raw format, normalize, write to intermediate.
            *   import delimited "$RAW_DIR/`file'", clear
            *   use "$RAW_DIR/file.dta", clear
            * ------------------------------------------------------------------
            import delimited "$RAW_DIR/`file'", clear
            log_message "  Loaded `c(N)' rows, `c(k)' columns"

            parse_and_clean

            local output_dta = subinstr("`file'", ".csv", ".dta", .)
            save "$INTERMEDIATE_DIR/`output_dta'", replace
            log_message "  Wrote: `output_dta'"
        }
    }

    log_message "Data ingestion completed successfully."
    close_logger
end

// Run if called directly
if "`c(mode)'" != "batch" {
    main
}
