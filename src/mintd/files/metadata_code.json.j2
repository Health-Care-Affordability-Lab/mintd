{
  "schema_version": "1.0",
  "mint": {
    "version": "{{ mint_version }}",
    "commit_hash": "{{ mint_hash }}"
  },
  "project": {
    "name": "{{ project_name }}",
    "type": "code",
    "full_name": "{{ project_name }}",
    "display_name": "{{ project_name | replace('_', ' ') | replace('-', ' ') | title }}",
    "created_at": "{{ created_at }}",
    "created_by": "{{ author }}"
  },
  "metadata": {
    "version": "1.0.0",
    "mint_version": "{{ mint_version }}",
    "description": "{{ description | default('') }}",
    "tags": {{ tags | default([]) | tojson }},
    "language": "{{ language }}"
  },
  "ownership": {
    "team": "{{ team }}",
    "maintainers": [
      "{{ author }}"
    ]
  },
  "access_control": {
    "teams": [
      {
        "name": "{{ admin_team }}",
        "permission": "admin"
      },
      {
        "name": "{{ researcher_team }}",
        "permission": "read"
      }
    ]
  },
  "status": {
    "state": "active",
    "last_updated": "{{ created_at }}"
  },
  "governance": {
    "classification": "{{ classification }}",
    "contract_info": "{{ contract_info | default('') }}"
  },
  "repository": {
    "github_url": "https://github.com/{{ registry_org }}/{{ project_name }}",
    "default_branch": "main",
    "visibility": "private",
    "mirror": {
      "url": "{{ mirror_url | default('') }}",
      "purpose": "{{ mirror_purpose | default('internal_tooling') }}"
    }
  }
}