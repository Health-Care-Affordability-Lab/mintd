{
  "schema_version": "1.1",
  "mint": {
    "version": "{{ mint_version }}",
    "commit_hash": "{{ mint_hash }}"
  },
  "project": {
    "name": "{{ project_name }}",
    "type": "{{ project_type }}",
    "full_name": "{{ full_project_name }}",
    "created_at": "{{ created_at }}",
    "created_by": "{{ author }}"
  },
  "metadata": {
    "version": "1.0.0",
    "description": "{{ description | default('') }}",
    "tags": {{ tags | default([]) | tojson }}
  },
  "ownership": {
    "team": "{{ team }}",
    "maintainers": [
      "{{ author }}"
    ]
  },
  "access_control": {
    "teams": [
      {
        "name": "{{ admin_team }}",
        "permission": "admin"
      },
      {
        "name": "{{ researcher_team }}",
        "permission": "read"
      }
    ]
  },
  "status": {
    "state": "active",
    "last_updated": "{{ created_at }}"
  },
  "governance": {
    "classification": "{{ classification }}",
    "contract_info": "{{ contract_info | default('') }}"
  },
  "storage": {
    "provider": "{{ storage_provider | default('s3') }}",
    "bucket": "{{ bucket_name | default('') }}",
    "prefix": "{{ storage_prefix }}",
    "endpoint": "{{ storage_endpoint | default('') }}",
    "versioning": {{ storage_versioning | default(true) | lower }},
    "dvc": {
      "remote_name": "{{ dvc_remote_name | default('') }}"
    }
  },
  "data_products": {
    "primary": "{{ data_products_primary | default('data/final/') }}",
    "outputs": {{ data_products_outputs | default([{"path": "data/final/", "description": "Cleaned analysis-ready dataset", "primary": true}]) | tojson }}
  },
  "repository": {
    "github_url": "https://github.com/{{ registry_org }}/{{ full_project_name }}",
    "default_branch": "main",
    "visibility": "private",
    "mirror": {
      "url": "{{ mirror_url | default('') }}",
      "purpose": "{{ mirror_purpose | default('') }}"
    }
  }
}
