vars:
  - dvc_vars.yaml

stages:
# ---------------------------------------------------------------------------
# Optional: uncomment the fetch stage to download raw data programmatically.
# When enabled, this is the ONLY stage that writes data/raw/.
# If raw data is hand-placed or tracked via `dvc add data/raw/`, leave this
# block commented out. See fetch.{py,R,do} for the matching script stub.
#
#  fetch:
#    wdir: {{ source_dir }}
#    cmd: YOUR_FETCH_CMD              # e.g. ${python_cmd} fetch.py
#    deps:
#      - YOUR_FETCH_SCRIPT           # e.g. fetch.py
#    outs:
#      - ../data/raw/
# ---------------------------------------------------------------------------
# These stages are a starting point, not a fixed set. Add your own stage
# (e.g. a `clean`/`harmonize` step between ingest and validate) whenever the
# ingest logic grows — just keep each stage's `deps`/`outs` chain connected so
# `dvc repro` can order the DAG.
# ---------------------------------------------------------------------------

  ingest:
    wdir: {{ source_dir }}
{% if language == "python" %}
    cmd: ${python_cmd} ingest.py
{% elif language == "r" %}
    cmd: ${r_cmd} ingest.R
{% elif language == "stata" %}
    cmd: ${stata_cmd} -b do ingest.do
{% endif %}
    deps:
{% if language == "python" %}
      - ingest.py
{% elif language == "r" %}
      - ingest.R
{% elif language == "stata" %}
      - ingest.do
      - _mintd_utils.do
{% endif %}
      - ../data/raw/
    outs:
      - ../data/intermediate/

  validate:
    wdir: {{ source_dir }}
{% if language == "python" %}
    cmd: ${python_cmd} validate.py
{% elif language == "r" %}
    cmd: ${r_cmd} validate.R
{% elif language == "stata" %}
    cmd: ${stata_cmd} -b do validate.do
{% endif %}
    deps:
{% if language == "python" %}
      - validate.py
{% elif language == "r" %}
      - validate.R
{% elif language == "stata" %}
      - validate.do
      - _mintd_utils.do
{% endif %}
      - ../data/intermediate/
    outs:
      - ../data/final/
{% if language != "stata" %}      - ../schemas/v1/schema.json
{% endif %}
{% if language == "stata" %}
  schema:
    wdir: {{ source_dir }}
    cmd: mintd data schema generate --project-dir ..
    deps:
      - ../data/final/
    outs:
      - ../schemas/v1/schema.json
{% endif %}
