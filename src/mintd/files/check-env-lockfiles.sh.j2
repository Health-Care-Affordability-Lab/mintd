#!/usr/bin/env bash
# Check that environment lockfiles exist for reproducibility
# Generated by mintd for {{ project_name }}

set -e

errors=0

# Python: if requirements.txt exists, requirements-lock.txt should too
if [ -f "requirements.txt" ]; then
    if [ ! -f "requirements-lock.txt" ]; then
        echo "ERROR: requirements.txt exists but requirements-lock.txt is missing"
        echo "  Run: pip freeze > requirements-lock.txt"
        errors=$((errors + 1))
    fi
fi

# R: if DESCRIPTION exists, check renv.lock has actual packages
if [ -f "DESCRIPTION" ] && [ -f "renv.lock" ]; then
    # Check if Packages section is empty (just {})
    if grep -q '"Packages": {}' renv.lock 2>/dev/null; then
        echo "WARNING: renv.lock has no packages recorded"
        echo "  Run: Rscript -e 'renv::snapshot()'"
        # Warning only, don't fail - R users may be setting up
    fi
fi

# Stata: just check the file exists (no lockfile mechanism)
# stata-packages.txt is generated by mintd, so no check needed

if [ $errors -gt 0 ]; then
    echo ""
    echo "Lockfile check failed. Please create lockfiles for reproducibility."
    exit 1
fi

exit 0
