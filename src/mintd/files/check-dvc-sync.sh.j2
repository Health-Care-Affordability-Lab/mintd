#!/usr/bin/env bash
# Check if pipeline sources changed without dvc.lock update
# Exit 0 = pass, Exit 1 = block commit
#
# Generated by mintd {{ mint_version }}

set -euo pipefail

{% if language == "stata" %}
PIPELINE_PATTERNS="{{ source_dir }}/.*\.(py|do)$|configs/.*\.do$|dvc\.yaml$|dvc_vars\.yaml$"
{% else %}
PIPELINE_PATTERNS="{{ source_dir }}/.*\.py$|dvc\.yaml$|dvc_vars\.yaml$"
{% endif %}
staged_files=$(git diff --cached --name-only)

# Check if any pipeline files are staged
pipeline_changed=$(echo "$staged_files" | grep -E "$PIPELINE_PATTERNS" || true)
lock_staged=$(echo "$staged_files" | grep "dvc.lock" || true)

if [[ -n "$pipeline_changed" && -z "$lock_staged" ]]; then
    echo "DVC Pipeline Sync Error"
    echo "------------------------"
    echo "Pipeline source files changed but dvc.lock was not updated."
    echo ""
    echo "Changed files:"
    echo "$pipeline_changed" | sed 's/^/  - /'
    echo ""
    echo "To fix, run:"
    echo "  dvc repro"
    echo "  git add dvc.lock"
    echo ""
    echo "If changes are cosmetic (comments only), bypass with:"
    echo "  git commit --no-verify"
    exit 1
fi
exit 0
