"""Data ingestion for {{ project_name }}.

Reads ``data/raw/`` (immutable source data), parses and normalizes it, and
writes ``data/intermediate/``. This is the first stage of the DVC pipeline
(``ingest`` -> ``validate``).

NOTE: This script runs from the code/ directory. Data paths use ../data/

data/raw/ is treated as IMMUTABLE: this script reads it but never writes to
it. To update raw data, either re-run the optional `fetch` stage (see
fetch.py / dvc.yaml) or run `dvc add data/raw/` after manually updating files.

For large datasets with expensive parsing, consider organizing this file as
two clearly-separated groups: `parse_*` functions that turn raw formats into
DataFrames, and `clean_*` functions that apply business-logic
standardization. The helpers in clean.py can be imported and called here.
"""

from pathlib import Path

import pandas as pd

# Import mint utilities (located in same code/ directory)
from _mintd_utils import (
    ParameterAwareLogger,
    RAW_DIR,
    INTERMEDIATE_DIR,
    get_data_paths,
)


def parse_and_clean(df, logger):
    """Normalize a raw DataFrame into analysis-ready intermediate form.

    Customize this with your project's parsing and cleaning logic. The default
    applies safe, generic standardization (drop empty rows, strip whitespace,
    normalize column names).
    """
    initial_rows = len(df)
    df = df.dropna(how="all")
    if initial_rows - len(df) > 0:
        logger.log(f"  Removed {initial_rows - len(df)} empty rows")

    string_cols = df.select_dtypes(include=["object"]).columns
    for col in string_cols:
        df[col] = df[col].astype(str).str.strip().replace("nan", pd.NA)
    if len(string_cols) > 0:
        logger.log(f"  Stripped whitespace from {len(string_cols)} string columns")

    df.columns = df.columns.str.lower().str.replace(" ", "_").str.replace("-", "_")
    logger.log(f"  Final row count: {len(df)}")
    return df


def main():
    """Read raw source data, normalize it, write to the intermediate directory."""
    logger = ParameterAwareLogger("ingest")
    logger.log("Starting data ingestion for {{ project_name }}...")

    # Ensure pipeline directories exist (raw is read-only here; do NOT write it).
    paths = get_data_paths()
    for name, path in paths.items():
        if name != "logs":  # logs already created by logger
            path.mkdir(parents=True, exist_ok=True)

    logger.log(f"Reading raw data from: {RAW_DIR}")
    logger.log(f"Writing intermediate data to: {INTERMEDIATE_DIR}")

    raw_files = list(RAW_DIR.glob("*.csv"))
    if not raw_files:
        logger.log(
            "No CSV files found in RAW_DIR. Place source data in data/raw/ "
            "(or run `dvc repro fetch` if using programmatic acquisition)."
        )
    else:
        logger.log(f"Found {len(raw_files)} raw file(s) to ingest")
        for raw_file in raw_files:
            logger.log(f"Processing: {raw_file.name}")
            # ------------------------------------------------------------------
            # CUSTOMIZE: read each raw format, normalize, write to intermediate.
            # Examples:
            #   CSV:         df = pd.read_csv(raw_file)
            #   Parquet:     df = pd.read_parquet(raw_file)
            #   Fixed-width: df = pd.read_fwf(raw_file, widths=[...])
            # ------------------------------------------------------------------
            df = pd.read_csv(raw_file)
            logger.log(f"  Loaded {len(df)} rows, {len(df.columns)} columns")

            df = parse_and_clean(df, logger)

            output_file = INTERMEDIATE_DIR / raw_file.name
            df.to_csv(output_file, index=False)
            logger.log(f"  Wrote: {output_file.name}")

    logger.log("Data ingestion completed successfully.")
    logger.close()


if __name__ == "__main__":
    main()
