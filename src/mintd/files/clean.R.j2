#' Data quality inspection helper for {{ project_name }}
#'
#' STANDALONE TOOL — this is NOT a DVC pipeline stage. The pipeline's cleaning
#' logic lives in ingest.R (which reads data/raw/ and writes data/intermediate/).
#' This script reads the already-ingested data/intermediate/ files and reports
#' what `clean_dataset` would change, WITHOUT writing any output. Use it to
#' audit data quality interactively after running the pipeline.
#'
#' Run it after `dvc repro ingest` has populated data/intermediate/.
#'
#' NOTE: This script runs from the code/ directory. Data paths use ../data/
#'
#' The cleaning functions below are importable utilities — ingest.R may source
#' this file and call `clean_dataset` directly.

# Import mint utilities (located in same code/ directory)
source("_mintd_utils.R")

# Load tidyverse for data manipulation
library(dplyr, warn.conflicts = FALSE)
library(readr)
library(stringr)

#' Apply standard cleaning operations to a data frame
#'
#' @param df Data frame to clean
#' @param logger Logger instance for logging
#' @return Cleaned data frame
clean_dataset <- function(df, logger) {
  initial_rows <- nrow(df)


  # Remove completely empty rows
  df <- df %>% filter(rowSums(is.na(.)) < ncol(.))
  empty_removed <- initial_rows - nrow(df)
  if (empty_removed > 0) {
    logger$log("  Removed ", empty_removed, " empty rows")
  }

  # Strip whitespace from character columns
  char_cols <- names(df)[sapply(df, is.character)]
  if (length(char_cols) > 0) {
    df <- df %>%
      mutate(across(all_of(char_cols), str_trim))
    logger$log("  Stripped whitespace from ", length(char_cols), " character columns")
  }

  # Standardize column names (lowercase, underscores)
  original_names <- names(df)
  names(df) <- names(df) %>%
    tolower() %>%
    str_replace_all(" ", "_") %>%
    str_replace_all("-", "_")
  renamed <- sum(original_names != names(df))
  if (renamed > 0) {
    logger$log("  Standardized ", renamed, " column names")
  }

  logger$log("  Final row count: ", nrow(df))
  return(df)
}

main <- function() {
  logger <- ParameterAwareLogger("clean")
  logger$log("Inspecting intermediate data quality for {{ project_name }}...")
  logger$log(
    "This is a read-only audit. It does NOT modify any files. ",
    "Run `dvc repro ingest` first if data/intermediate/ is empty."
  )

  intermediate_files <- list.files(INTERMEDIATE_DIR, pattern = "\\.csv$", full.names = TRUE)
  if (length(intermediate_files) == 0) {
    logger$log("No CSV files found in INTERMEDIATE_DIR. Run `dvc repro ingest` first.")
  } else {
    logger$log("Found ", length(intermediate_files), " intermediate file(s) to inspect")
    for (data_file in intermediate_files) {
      logger$log("Inspecting: ", basename(data_file))
      df <- read_csv(data_file, show_col_types = FALSE)
      logger$log("  Loaded ", nrow(df), " rows, ", ncol(df), " columns")
      # Report what cleaning would change; discard the result (no write).
      invisible(clean_dataset(df, logger))
    }
  }

  logger$log("Data quality inspection completed.")
  logger$close()
}

if (!interactive()) {
  main()
}
