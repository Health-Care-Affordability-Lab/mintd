* Data quality inspection helper for {{ project_name }}
*
* STANDALONE TOOL — this is NOT a DVC pipeline stage. The pipeline's cleaning
* logic lives in ingest.do (which reads data/raw/ and writes data/intermediate/).
* This do-file reads the already-ingested data/intermediate/ files and reports
* what clean_dataset would change, WITHOUT writing any output. Use it to audit
* data quality interactively after running the pipeline.
*
* Run it after `dvc repro ingest` has populated data/intermediate/.
*
* NOTE: This script runs from the code/ directory. Data paths use ../data/

* Import mint utilities (located in same code/ directory)
do _mintd_utils.do

* Clean dataset program (importable utility; ingest.do may call it)
capture program drop clean_dataset
program define clean_dataset
    args dataset_name

    local initial_rows = _N

    * Remove completely empty rows (all missing)
    egen _row_missing = rowmiss(_all)
    local total_vars = c(k) - 1  // exclude _row_missing
    drop if _row_missing == `total_vars'
    local empty_removed = `initial_rows' - _N
    drop _row_missing

    if `empty_removed' > 0 {
        log_message "  Removed `empty_removed' empty rows"
    }

    * Strip whitespace from string variables
    local string_count = 0
    foreach var of varlist _all {
        capture confirm string variable `var'
        if !_rc {
            replace `var' = strtrim(`var')
            local ++string_count
        }
    }
    if `string_count' > 0 {
        log_message "  Stripped whitespace from `string_count' string variables"
    }

    * Standardize variable names (lowercase)
    rename *, lower

    log_message "  Final row count: `c(N)'"
end

// Main inspection program — reads INTERMEDIATE_DIR, writes nothing.
capture program drop main
program define main
    ParameterAwareLogger clean
    log_message "Inspecting intermediate data quality for {{ project_name }}..."
    log_message "This is a read-only audit. It does NOT modify any files."
    log_message "Run dvc repro ingest first if data/intermediate/ is empty."

    * Inspect all .dta files in INTERMEDIATE_DIR
    local inter_files : dir "$INTERMEDIATE_DIR" files "*.dta"
    local file_count : word count `inter_files'

    if `file_count' == 0 {
        log_message "No .dta files found in INTERMEDIATE_DIR. Run: dvc repro ingest"
    }
    else {
        log_message "Found `file_count' intermediate file(s) to inspect"

        foreach file of local inter_files {
            log_message "Inspecting: `file'"

            * Load intermediate data
            use "$INTERMEDIATE_DIR/`file'", clear
            log_message "  Loaded `c(N)' rows, `c(k)' columns"

            * Report what cleaning would change (in-memory only; nothing saved)
            clean_dataset "`file'"
        }
    }

    log_message "Data quality inspection completed."
    close_logger
end

// Run if called directly
if "`c(mode)'" != "batch" {
    main
}
