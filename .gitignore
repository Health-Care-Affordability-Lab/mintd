# Python bytecode and build artifacts
__pycache__/
*.py[cod]
*$py.class
*.egg
*.egg-info/
build/
dist/

# Virtualenv
.venv/
venv/
env/
ENV/

# Tool caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.nox/

# Coverage
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover

# Editor / OS
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# Environment files
.env
.envrc

# DVC runtime droppings in the pipeline fixture: tests run real dvc
# against this fixture, which recreates .dvc/tmp, .dvc/cache, and its
# own .gitignore. Only the checked-in config is real fixture content.
tests/fixtures/pipeline_project/.dvc/*
!tests/fixtures/pipeline_project/.dvc/config

# Local-only working notes (slice specs, retros, decisions, plan refs)
notes/
.agents
.pi
.codex
.agent-sync
.venv
.claude
.forge-scout/
